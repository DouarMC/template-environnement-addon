        },
        {
            "fileMatch": ["behavior_packs/*/manifest.json"],
            "url": "https://douarmc.github.io/minecraft-bedrock-json-schemas/behavior_pack/BP-manifest.json.schema.json"
        },
        {
            "fileMatch": ["resource_packs/*/manifest.json"],
            "url": "https://douarmc.github.io/minecraft-bedrock-json-schemas/resource_pack/RP-manifest.json.schema.json"
        },
        {
            "fileMatch": ["behavior_packs/*/texts/languages.json"],
